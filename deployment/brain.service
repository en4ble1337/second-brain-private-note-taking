[Unit]
Description=Local Second Brain
After=network-online.target ollama.service
Wants=network-online.target ollama.service

[Service]
Type=simple
User=REPLACE_USER
Group=REPLACE_USER
WorkingDirectory=REPLACE_DIR

# Environment
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=REPLACE_DIR/.env

# Use authbind so port 80 is accessible without root
ExecStart=/usr/bin/authbind --deep REPLACE_DIR/.venv/bin/uvicorn \
    src.main:app \
    --host 0.0.0.0 \
    --port 80 \
    --workers 1 \
    --no-access-log

Restart=on-failure
RestartSec=5
TimeoutStopSec=15

# Security hardening
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
